# SnipeWins environment configuration template.
# Copy this to `.env` and fill in real values. The real .env is .gitignored
# so secrets never get pushed to GitHub. On Render, set each of these as
# Environment Variables in the dashboard instead — Render doesn't read .env.

# ── eBay API (required for the scanner to work) ────────────────────────────
EBAY_CLIENT_ID=your-ebay-client-id
EBAY_CLIENT_SECRET=your-ebay-client-secret
EBAY_MARKETPLACE_ID=EBAY_US
EBAY_FINDING_APP_ID=your-ebay-finding-app-id

# ── Pushover (optional — for phone alerts) ────────────────────────────────
PUSHOVER_USER_KEY=your-pushover-user-key
PUSHOVER_API_TOKEN=your-pushover-api-token

# ── Resend (transactional email — magic links, password resets) ──────────
# Sign up at resend.com, verify snipewins.com as a sending domain, then
# create an API key. Domain must be verified before sends succeed.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Optional overrides — both default to hello@snipewins.com:
# SNIPEWINS_EMAIL_FROM=SnipeWins <hello@snipewins.com>
# SNIPEWINS_EMAIL_REPLY_TO=hello@snipewins.com

# ── Streamlit app public URL (used in magic-link email bodies) ───────────
# Local dev:  http://localhost:8501
# Production: https://snipewins-app.onrender.com (or your custom domain)
SNIPEWINS_APP_BASE_URL=http://localhost:8501

# ── Stripe Payment Links (paywall CTAs) ──────────────────────────────────
# Create the products + payment links in your Stripe dashboard, then paste
# the URLs here. Until set, paywall buttons no-op.
SNIPEWINS_STRIPE_URL=https://buy.stripe.com/your-annual-link
SNIPEWINS_STRIPE_TRIAL_URL=https://buy.stripe.com/your-monthly-trial-link
